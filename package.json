{
  "name": "@signalk/signalk-to-nmea0183",
  "version": "1.13.5",
  "description": "Signal K server plugin to convert Signal K to NMEA0183",
  "repository": {
    "url": "https://github.com/SignalK/signalk-to-nmea0183"
  },
  "main": "index.js",
  "scripts": {
    "test": "mocha",
    "coverage": "c8 --reporter=text --reporter=lcov npm test",
    "format": "prettier-standard '*.js*' 'sentences/*.js'"
  },
  "keywords": [
    "signalk-node-server-plugin"
  ],
  "author": "teppo.kurki@iki.fi",
  "license": "ISC",
  "peerDependencies": {
    "baconjs": "^3.0.0"
  },
  "devDependencies": {
    "baconjs": "^3.0.0",
    "c8": "^11.0.0",
    "mocha": "^11.7.1",
    "prettier-standard": "^16.4.1"
  },
  "c8": {
    "include": [
      "index.js",
      "sentences/**"
    ],
    "exclude": [
      "test/**",
      "coverage/**"
    ]
  }
}
